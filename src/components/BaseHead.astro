---
/**
 * BaseHead.astro
 * SEO / OGP / Twitter Card メタタグを一元管理するコンポーネント
 */

interface Props {
  title: string;
  description: string;
  canonicalURL?: URL | string;
  /** OGP 画像のパス（先頭スラッシュあり、例: /og-image.png） */
  ogImage?: string;
}

const {
  title,
  description,
  canonicalURL = Astro.url,
  ogImage = '/og-image.png',
} = Astro.props;

const siteURL = 'https://www.yamada-lab.co.jp';
const ogImageURL = `${siteURL}${ogImage}`;
---

<!-- Charset & Viewport -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="山田ラボ合同会社" />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="山田ラボ合同会社 - セキュアな認証ソリューション" />
<meta property="og:site_name" content="山田ラボ合同会社" />
<meta property="og:locale" content="ja_JP" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:image:alt" content="山田ラボ合同会社 - セキュアな認証ソリューション" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Google Fonts（非ブロッキングロード） -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<!-- preload: フォントCSSを先読み -->
<link
  rel="preload"
  as="style"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
/>
<!-- media="print" trick: レンダーブロッキングを回避しつつ読み込み後にすべての画面へ適用 -->
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
  media="print"
  onload="this.media='all'"
/>
<!-- JS無効環境向けフォールバック -->
<noscript>
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
  />
</noscript>

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Theme Color -->
<meta name="theme-color" content="#020617" />
