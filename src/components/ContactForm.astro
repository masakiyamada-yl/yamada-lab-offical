---
/**
 * ContactForm.astro
 * お問い合わせフォームセクション
 * Google Apps Script (GAS) へ fetch POST 送信
 * スクロールアニメーション・ARIA対応・バリデーション対応
 */

const GAS_URL =
  'https://script.google.com/macros/s/AKfycbx-IftvWDli_VrQ-j8T51m9FcJq3KU3A-RdA8BK-WIe3fnj5z7LFaTlauXSYulE97cpGQ/exec';
---

<section
  id="contact"
  class="py-24 md:py-32 border-t border-white/5 relative overflow-hidden"
  aria-labelledby="contact-heading"
>
  <!-- 背景グラデーション -->
  <div
    class="absolute left-0 top-0 w-1/2 h-full bg-gradient-to-r from-blue-900/10 to-transparent pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="max-w-2xl mx-auto js-animate">

      <!-- セクションヘッダー -->
      <header class="text-center mb-12">
        <h2
          id="contact-heading"
          class="text-4xl md:text-5xl font-bold mb-4"
        >
          お問い合わせ
        </h2>
        <p class="text-slate-400 text-lg">
          ご質問・ご相談はお気軽にお問い合わせください。<br class="hidden md:block" />
          担当者より折り返しご連絡いたします。
        </p>
      </header>

      <!-- 送信成功表示 -->
      <div
        id="contact-success"
        class="hidden flex-col items-center justify-center py-16 gap-4"
        role="alert"
        aria-live="polite"
      >
        <!-- CheckCircle icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="64"
          height="64"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-green-400"
          aria-hidden="true"
        >
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        <h3 class="text-xl font-bold">送信が完了しました</h3>
        <p class="text-slate-400 text-center">
          お問い合わせありがとうございます。<br />
          内容を確認の上、担当者よりご連絡いたします。
        </p>
        <button
          id="contact-reset-btn"
          type="button"
          class="mt-4 px-6 py-2.5 rounded-full bg-white/5 border border-white/10 text-sm hover:bg-white/10 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-400 rounded-full"
        >
          新しいお問い合わせ
        </button>
      </div>

      <!-- お問い合わせフォーム -->
      <form
        id="contact-form"
        class="space-y-6"
        novalidate
        aria-label="お問い合わせフォーム"
      >
        <!-- お名前 / メールアドレス -->
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label for="contact-name" class="block text-sm text-slate-400 mb-2">
              お名前 <span class="text-blue-400" aria-label="必須">*</span>
            </label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
              placeholder="山田 太郎"
              class="w-full px-4 py-3 rounded-xl bg-white/[0.04] border border-white/10 text-slate-100 placeholder-slate-600 focus:outline-none focus:border-blue-500/50 focus:bg-white/[0.06] transition-all"
              aria-required="true"
            />
          </div>
          <div>
            <label for="contact-email" class="block text-sm text-slate-400 mb-2">
              メールアドレス <span class="text-blue-400" aria-label="必須">*</span>
            </label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
              placeholder="taro@example.com"
              class="w-full px-4 py-3 rounded-xl bg-white/[0.04] border border-white/10 text-slate-100 placeholder-slate-600 focus:outline-none focus:border-blue-500/50 focus:bg-white/[0.06] transition-all"
              aria-required="true"
            />
          </div>
        </div>

        <!-- 件名 -->
        <div>
          <label for="contact-subject" class="block text-sm text-slate-400 mb-2">
            件名 <span class="text-blue-400" aria-label="必須">*</span>
          </label>
          <input
            type="text"
            id="contact-subject"
            name="subject"
            required
            placeholder="お問い合わせ内容の件名"
            class="w-full px-4 py-3 rounded-xl bg-white/[0.04] border border-white/10 text-slate-100 placeholder-slate-600 focus:outline-none focus:border-blue-500/50 focus:bg-white/[0.06] transition-all"
            aria-required="true"
          />
        </div>

        <!-- メッセージ -->
        <div>
          <label for="contact-message" class="block text-sm text-slate-400 mb-2">
            メッセージ <span class="text-blue-400" aria-label="必須">*</span>
          </label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows={6}
            placeholder="お問い合わせ内容をご記入ください"
            class="w-full px-4 py-3 rounded-xl bg-white/[0.04] border border-white/10 text-slate-100 placeholder-slate-600 focus:outline-none focus:border-blue-500/50 focus:bg-white/[0.06] transition-all resize-none"
            aria-required="true"
          ></textarea>
        </div>

        <!-- エラーメッセージ -->
        <div
          id="contact-error"
          class="hidden items-center gap-3 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm"
          role="alert"
          aria-live="assertive"
        >
          <!-- AlertCircle icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="shrink-0"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <span id="contact-error-text">送信に失敗しました。時間をおいて再度お試しください。</span>
        </div>

        <!-- 送信ボタン -->
        <button
          id="contact-submit-btn"
          type="submit"
          class="w-full flex items-center justify-center gap-2 px-8 py-4 rounded-full bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-500 hover:to-cyan-500 disabled:opacity-50 disabled:cursor-not-allowed text-white font-medium transition-all shadow-lg shadow-blue-500/20 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-slate-950"
        >
          <!-- Send icon -->
          <svg
            id="contact-send-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
          <!-- スピナー（送信中） -->
          <span
            id="contact-spinner"
            class="hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"
            aria-hidden="true"
          ></span>
          <span id="contact-btn-text">送信する</span>
        </button>

        <p class="text-xs text-slate-600 text-center">
          送信先：contact@yamada-lab.co.jp
        </p>
      </form>

    </div>
  </div>
</section>

<script define:vars={{ GAS_URL }}>
  const form = document.getElementById('contact-form');
  const successEl = document.getElementById('contact-success');
  const errorEl = document.getElementById('contact-error');
  const errorText = document.getElementById('contact-error-text');
  const submitBtn = document.getElementById('contact-submit-btn');
  const sendIcon = document.getElementById('contact-send-icon');
  const spinner = document.getElementById('contact-spinner');
  const btnText = document.getElementById('contact-btn-text');
  const resetBtn = document.getElementById('contact-reset-btn');

  function setLoading(loading) {
    submitBtn.disabled = loading;
    sendIcon.classList.toggle('hidden', loading);
    spinner.classList.toggle('hidden', !loading);
    btnText.textContent = loading ? '送信中...' : '送信する';
  }

  function showError(message) {
    errorText.textContent = message || '送信に失敗しました。時間をおいて再度お試しください。';
    errorEl.classList.remove('hidden');
    errorEl.classList.add('flex');
  }

  function hideError() {
    errorEl.classList.add('hidden');
    errorEl.classList.remove('flex');
  }

  function showSuccess() {
    form.classList.add('hidden');
    successEl.classList.remove('hidden');
    successEl.classList.add('flex');
  }

  function resetForm() {
    form.reset();
    form.classList.remove('hidden');
    successEl.classList.add('hidden');
    successEl.classList.remove('flex');
    hideError();
  }

  resetBtn.addEventListener('click', resetForm);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    // HTML5 バリデーション
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    setLoading(true);

    const data = {
      name: form.querySelector('#contact-name').value.trim(),
      email: form.querySelector('#contact-email').value.trim(),
      subject: form.querySelector('#contact-subject').value.trim(),
      message: form.querySelector('#contact-message').value.trim(),
    };

    try {
      const res = await fetch(GAS_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        mode: 'no-cors', // GASはno-corsが必要
      });
      // no-cors の場合はレスポンスが opaque になるため成功とみなす
      showSuccess();
    } catch (err) {
      console.error('Contact form error:', err);
      showError('送信に失敗しました。時間をおいて再度お試しください。');
    } finally {
      setLoading(false);
    }
  });

  // スクロールアニメーション
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-fade-up');
          entry.target.style.opacity = '1';
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '-60px' }
  );

  document.querySelectorAll('#contact .js-animate').forEach((el) => {
    el.style.opacity = '0';
    observer.observe(el);
  });
</script>
