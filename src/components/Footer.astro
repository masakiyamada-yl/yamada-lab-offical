---
/**
 * Footer.astro
 * サイトフッター（正式社名・コピーライト・プライバシーポリシーリンク）
 */
const year = new Date().getFullYear();
---

<footer class="py-12 border-t border-white/10 bg-slate-950" role="contentinfo">
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col items-center text-center gap-4">

    <!-- ロゴ・会社名 -->
    <div class="flex items-center gap-2" aria-label="会社名">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-blue-500"
        aria-hidden="true"
      >
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      </svg>
      <span class="text-lg font-bold tracking-tight text-slate-300">Yamada Lab LLC</span>
    </div>

    <!-- プライバシーポリシー（2段目） -->
    <p class="text-sm text-slate-500">
      <button
        id="privacy-open-btn"
        type="button"
        class="hover:text-blue-400 transition-colors underline focus:outline-none focus:ring-2 focus:ring-blue-400 rounded"
        aria-haspopup="dialog"
        aria-controls="privacy-modal"
      >
        プライバシーポリシー
      </button>
    </p>

    <!-- コピーライト（最下段） -->
    <p class="text-sm text-slate-500">
      &copy; {year} Yamada Lab LLC. All rights reserved.
    </p>

  </div>
</footer>

<!-- ===== プライバシーポリシーモーダル ===== -->
<div
  id="privacy-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="privacy-modal-title"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/70 backdrop-blur-sm"
>
  <div
    id="privacy-modal-panel"
    class="bg-slate-900 border border-white/10 rounded-2xl max-w-2xl w-full max-h-[80vh] overflow-y-auto p-8"
  >
    <div class="flex justify-between items-center mb-6">
      <h2 id="privacy-modal-title" class="text-2xl font-bold text-white">
        プライバシーポリシー
      </h2>
      <button
        id="privacy-close-btn"
        type="button"
        class="text-slate-400 hover:text-white transition-colors p-1 focus:outline-none focus:ring-2 focus:ring-blue-400 rounded"
        aria-label="プライバシーポリシーを閉じる"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <div class="text-slate-300 space-y-5 text-sm leading-relaxed">
      <section>
        <h3 class="font-semibold text-white mb-1">1. 個人情報の取得</h3>
        <p>当サービスでは、お問い合わせフォームにて氏名・メールアドレス等の個人情報を取得することがあります。</p>
      </section>
      <section>
        <h3 class="font-semibold text-white mb-1">2. 利用目的</h3>
        <p>取得した個人情報は、お問い合わせへの返答、サービス提供に関する連絡のために利用します。</p>
      </section>
      <section>
        <h3 class="font-semibold text-white mb-1">3. 第三者への提供</h3>
        <p>法令に基づく場合を除き、ご本人の同意なく第三者へ提供することはありません。</p>
      </section>
      <section>
        <h3 class="font-semibold text-white mb-1">4. 個人情報の管理</h3>
        <p>取得した個人情報は、不正アクセス・紛失・改ざん等を防ぐため、適切に管理します。</p>
      </section>
      <section>
        <h3 class="font-semibold text-white mb-1">5. 個人情報の開示・訂正・削除について</h3>
        <p>ご本人から個人情報の開示・訂正・削除を求められた場合は、速やかに対応いたします。</p>
      </section>
      <section>
        <h3 class="font-semibold text-white mb-1">6. お問い合わせ</h3>
        <p>
          個人情報の取扱いに関するお問い合わせは
          <a
            href="mailto:contact@yamada-lab.co.jp"
            class="text-blue-400 hover:underline focus:outline-none focus:ring-2 focus:ring-blue-400 rounded"
          >
            contact@yamada-lab.co.jp
          </a>
          までご連絡ください。
        </p>
      </section>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('privacy-modal')!;
  const openBtn = document.getElementById('privacy-open-btn')!;
  const closeBtn = document.getElementById('privacy-close-btn')!;
  const panel = document.getElementById('privacy-modal-panel')!;

  function openModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
    openBtn.focus();
  }

  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);

  modal.addEventListener('click', (e) => {
    if (!panel.contains(e.target as Node)) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
</script>
