---
/**
 * Hero.astro
 * 茫聝聲茫聜隆茫聝录茫聜鹿茫聝聢茫聝聯茫聝楼茫聝录茂录聢茫聝聲茫聝芦茫聜鹿茫聜炉茫聝陋茫聝录茫聝鲁茫聝聮茫聝录茫聝颅茫聝录茂录聣
 * 茫聜鹿茫聜炉茫聝颅茫聝录茫聝芦茫聜垄茫聝聥茫聝隆茫聝录茫聜路茫聝搂茫聝鲁氓炉戮氓驴聹
 */
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-slate-950"
  aria-label="茫聝聮茫聝录茫聝颅茫聝录茫聜禄茫聜炉茫聜路茫聝搂茫聝鲁"
>
  <!-- 猫聝聦忙聶炉茫聜掳茫聝漏茫聝聡茫聝录茫聜路茫聝搂茫聝鲁 -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-slate-950 via-blue-950/30 to-slate-950"
    aria-hidden="true"
  ></div>

  <!-- 猫拢聟茅拢戮茫聜掳茫聝陋茫聝聝茫聝聣 -->
  <div
    class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg%20fill%3D%22none%22%20fill-rule%3D%22evenodd%22%3E%3Cg%20fill%3D%22%234f6af5%22%20fill-opacity%3D%220.03%22%3E%3Ccircle%20cx%3D%221%22%20cy%3D%221%22%20r%3D%221%22%2F%3E%3C%2Fg%3E%3C%2Fg%3E%3C%2Fsvg%3E')]"
    aria-hidden="true"
  ></div>

  <!-- 茫聜掳茫聝颅茫聝录氓聤鹿忙聻聹 -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-blue-600/5 blur-3xl"
    aria-hidden="true"
  ></div>

  <!-- 茫聜鲁茫聝鲁茫聝聠茫聝鲁茫聝聞 -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 text-center">


    <!-- 茫聝隆茫聜陇茫聝鲁茫聜鲁茫聝聰茫聝录 -->
    <h1
      class="text-5xl md:text-7xl font-bold tracking-tight mb-6 opacity-0 animate-fade-up"
      style="animation-delay: 0.2s; animation-fill-mode: forwards;"
    >
      盲赂聳莽聲聦茫聜聮<br />
      <span class="bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
        盲赂聙茫聛陇茫聛庐猫陋聧猫篓录
      </span>茫聛搂莽鹿聥茫聛聬茫聙聜
    </h1>

    <!-- 茫聜碌茫聝聳茫聜鲁茫聝聰茫聝录 -->
    <p
      class="text-lg md:text-xl text-slate-400 max-w-xl mx-auto mb-12 leading-relaxed opacity-0 animate-fade-up"
      style="animation-delay: 0.3s; animation-fill-mode: forwards;"
    >
      OpenRoaming忙聤聙猫隆聯茫聛篓氓录路氓聸潞茫聛陋猫陋聧猫篓录氓聼潞莽聸陇茫聛芦茫聜聢茫聜聤茫聙聛氓聸陆氓垄聝茫聜聞茫聝聧茫聝聝茫聝聢茫聝炉茫聝录茫聜炉茫聛庐氓拢聛茫聜聮猫露聤茫聛聢茫聛聼茫聜路茫聝录茫聝聽茫聝卢茫聜鹿茫聛搂氓庐聣氓聟篓茫聛陋茅聙職盲驴隆盲陆聯茅篓聯茫聜聮忙聫聬盲戮聸茫聛聴茫聛戮茫聛聶茫聙聜
    </p>

    <!-- CTA -->
    <div
      class="opacity-0 animate-fade-up"
      style="animation-delay: 0.4s; animation-fill-mode: forwards;"
    >
      <a
        href="#services"
        class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-500 hover:to-cyan-500 text-white font-semibold rounded-full shadow-2xl shadow-blue-500/30 transition-all duration-200 hover:shadow-blue-500/50 hover:scale-105 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-slate-950"
        aria-label="盲潞聥忙楼颅氓聠聟氓庐鹿茫聛庐茫聜禄茫聜炉茫聜路茫聝搂茫聝鲁茫聛赂莽搂禄氓聥聲"
      >
        <span>茫聜陆茫聝陋茫聝楼茫聝录茫聜路茫聝搂茫聝鲁茫聜聮猫娄聥茫聜聥</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </a>
    </div>
  </div>

  <!-- 茫聜鹿茫聜炉茫聝颅茫聝录茫聝芦茫聜陇茫聝鲁茫聜赂茫聜卤茫聝录茫聜驴茫聝录 -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-500 text-xs opacity-0 animate-fade-in"
    style="animation-delay: 1s; animation-fill-mode: forwards;"
    aria-hidden="true"
  >
    <span>Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-slate-500 to-transparent"></div>
  </div>
</section>
