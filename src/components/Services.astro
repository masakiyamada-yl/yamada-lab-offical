---
/**
 * Services.astro
 * 事業内容セクション（3つのサービスカード）
 * スクロールアニメーション対応・ARIA対応
 */

const services = [
  {
    icon: 'wifi',
    title: '通信インフラ',
    description:
      '電気通信事業法に基づく確かな電気通信事業を展開。コンピュータシステムおよび通信ネットワークのインフラ構築、設計、コンサルティングを提供します。',
    features: ['電気通信事業', 'インフラ構築・設計', 'ネットワークコンサルティング'],
  },
  {
    icon: 'lock',
    title: '認証ソリューション',
    description:
      'OpenRoamingをはじめとする次世代の認証システムの企画、開発、運用及び保守。セキュアでシームレスな接続環境を実現します。',
    features: ['認証システム開発', 'OpenRoaming連携', 'セキュリティ保守運用'],
  },
  {
    icon: 'code',
    title: 'システム開発',
    description:
      '情報通信システム機器・ソフトウェアの製造、販売。インターネットを利用した情報提供サービスや、先進的なアプリケーションの制作・運営を行います。',
    features: ['ソフトウェア製造・販売', 'アプリ制作・運営', '情報提供サービス'],
  },
];

const iconPaths: Record<string, string> = {
  wifi: '<path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1"/>',
  lock: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
};
---

<section
  id="services"
  class="py-24 md:py-32 bg-slate-950"
  aria-labelledby="services-heading"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <!-- セクションヘッダー -->
    <header class="text-center mb-16 js-animate">
      <h2
        id="services-heading"
        class="text-4xl md:text-5xl font-bold mb-4"
      >
        事業内容
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        高度なセキュリティと利便性を両立する、次世代のインフラストラクチャを構築します。
      </p>
    </header>

    <!-- サービスカードグリッド -->
    <ul
      class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8"
      role="list"
      aria-label="提供サービス一覧"
    >
      {services.map((service, index) => (
        <li
          class="js-animate group relative p-8 bg-gradient-to-br from-white/5 to-white/[0.02] border border-white/10 rounded-2xl hover:border-blue-500/30 transition-all duration-300 hover:bg-white/[0.05]"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <!-- アイコン -->
          <div
            class="mb-6 inline-flex p-3 rounded-xl bg-blue-500/10 text-blue-400 group-hover:bg-blue-500/20 transition-colors"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={iconPaths[service.icon]}
            />
          </div>

          <!-- タイトル -->
          <h3 class="text-xl font-bold mb-3">{service.title}</h3>

          <!-- 説明文 -->
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            {service.description}
          </p>

          <!-- 機能リスト -->
          <ul class="space-y-2" aria-label={`${service.title}のサービス内容`}>
            {service.features.map((feature) => (
              <li class="flex items-center gap-2 text-sm text-slate-300">
                <span
                  class="w-1.5 h-1.5 rounded-full bg-blue-400 flex-shrink-0"
                  aria-hidden="true"
                ></span>
                {feature}
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  // スクロールアニメーション（Intersection Observer）
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-fade-up');
          (entry.target as HTMLElement).style.opacity = '1';
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05, rootMargin: '0px' }
  );

  document.querySelectorAll('#services .js-animate').forEach((el) => {
    (el as HTMLElement).style.opacity = '0';
    observer.observe(el);
  });
</script>
