---
/**
 * Layout.astro
 * サイト全体の基本レイアウト
 * BaseHead（SEO）・StructuredData・Header・Footerを統合
 */

import BaseHead from '../components/BaseHead.astro';
import StructuredData from '../components/StructuredData.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalURL?: URL | string;
  ogImage?: string;
}

const {
  title,
  description,
  canonicalURL,
  ogImage,
} = Astro.props;
---

<!doctype html>
<html lang="ja" class="scroll-smooth">
  <head>
    <BaseHead
      title={title}
      description={description}
      canonicalURL={canonicalURL}
      ogImage={ogImage}
    />
    <StructuredData />
  </head>
  <body class="bg-slate-950 text-white antialiased">
    <!-- スキップナビゲーション（アクセシビリティ） -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-blue-600 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-slate-950"
    >
      メインコンテンツへスキップ
    </a>

    <Header />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
